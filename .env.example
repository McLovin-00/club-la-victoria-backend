# Puerto del servidor
PORT=3001
# Host del servidor (IP para acceder desde otros dispositivos en la red)
HOST=0.0.0.0
NODE_ENV=development

# Configuración de base de datos Postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=club_la_victoria
DATABASE_USER=postgres
DATABASE_PASSWORD=your_database_password_here
DATABASE_TIMEZONE=SYSTEM

# Configuración de autenticación JWT
JWT_SECRET=your_jwt_secret_here_min_32_characters
JWT_EXPIRES_IN=604800

# Configuración de Cloudinary
CLOUDINARY_NAME=your_cloudinary_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# CORS - Orígenes permitidos
# Para desarrollo con app mobile, usar * o listar los orígenes:
# CORS_ORIGIN=http://localhost:3000,http://localhost:8081,http://192.168.1.X:3000
# Para desarrollo general:
CORS_ORIGIN=*
# Para producción, usar dominios específicos:
# CORS_ORIGIN=https://tudominio.com

# Tarjeta del Centro
TARJETA_CENTRO_PREFIX=C0019094
TARJETA_CENTRO_EMISOR=4310050019094
TARJETA_CENTRO_NOMBRE=CLUB DE CAZADORES LA
TARJETA_CENTRO_PERIOD_CONFIG={"2026-02":{"fechaCabecera":"220226","fechaTrailer":"230226","extensionArchivo":"23f","codigoPeriodoDetalle":"000002/261"}}
TARJETA_CENTRO_FALLBACK_HEADER_DAY=22
TARJETA_CENTRO_FALLBACK_TRAILER_DAY=23
TARJETA_CENTRO_FALLBACK_MONTH_LETTER_MAP={"01":"e","02":"f","03":"m","04":"b","05":"y","06":"j","07":"l","08":"a","09":"s","10":"o","11":"n","12":"d"}
